{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">

    {# ── Alert messages ───────────────────────────────────────────────────── #}
    {% if error_warnings %}
    <div class="alert alert-danger alert-dismissible">
      <i class="fa fa-exclamation-circle"></i>
      <ul class="list-unstyled" style="margin:0;">
        {% for error_warning in error_warnings %}
        <li>{{ error_warning|e }}</li>
        {% endfor %}
      </ul>
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {% if success_messages %}
    <div class="alert alert-success alert-dismissible">
      <i class="fa fa-check-circle"></i>
      <ul class="list-unstyled" style="margin:0;">
        {% for success_message in success_messages %}
        <li>{{ success_message|e }}</li>
        {% endfor %}
      </ul>
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}

    {# ══════════════════════════════════════════════════════════════════════ #}
    {# PANEL 1 — Installed Languages                                          #}
    {# ══════════════════════════════════════════════════════════════════════ #}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-language"></i> {{ text_installed_languages }}</h3>
      </div>
      <div class="panel-body">
        <div class="table-responsive">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th>{{ column_name }}</th>
                <th>{{ column_code }}</th>
                <th>{{ column_directory }}</th>
                <th>{{ column_locale }}</th>
                <th class="text-center">{{ column_status }}</th>
                <th class="text-right">{{ column_action }}</th>
              </tr>
            </thead>
            <tbody>
              {% for language in languages %}
              <tr>
                <td>{{ language.name }}</td>
                <td><code>{{ language.code }}</code></td>
                <td><code>{{ language.directory }}</code></td>
                <td><small>{{ language.locale }}</small></td>
                <td class="text-center">
                  {% if language.status %}
                  <span class="label label-success">{{ text_enabled }}</span>
                  {% else %}
                  <span class="label label-default">{{ text_disabled }}</span>
                  {% endif %}
                </td>
                <td class="text-right">
                  <div class="btn-group">
                    {% if language.status %}
                    <a href="{{ language.url_disable }}" class="btn btn-sm btn-warning" title="{{ button_disable }}">
                      <i class="fa fa-toggle-off"></i> {{ button_disable }}
                    </a>
                    {% else %}
                    <a href="{{ language.url_enable }}" class="btn btn-sm btn-success" title="{{ button_enable }}">
                      <i class="fa fa-toggle-on"></i> {{ button_enable }}
                    </a>
                    {% endif %}
                    <button type="button"
                            class="btn btn-sm btn-info btn-scan"
                            data-directory="{{ language.directory }}"
                            data-url="{{ language.url_scan }}"
                            title="{{ button_scan }}">
                      <i class="fa fa-search"></i> {{ button_scan }}
                    </button>
                    <button type="button"
                           class="btn btn-sm btn-default btn-language-action"
                           data-directory="{{ language.directory }}"
                           data-url="{{ language.url_scaffold }}"
                           data-confirm="{{ text_confirm_scaffold }}"
                           data-title="{{ button_scaffold }}"
                           data-mode="scaffold"
                           title="{{ button_scaffold }}">
                      <i class="fa fa-files-o"></i> {{ button_scaffold }}
                    </button>
                    <button type="button"
                           class="btn btn-sm btn-primary btn-language-action"
                           data-directory="{{ language.directory }}"
                           data-url="{{ language.url_sync_keys }}"
                           data-confirm="{{ text_confirm_sync_keys }}"
                           data-title="{{ button_sync_keys }}"
                           data-mode="sync"
                           title="{{ button_sync_keys }}">
                     <i class="fa fa-refresh"></i> {{ button_sync_keys }}
                    </button>
                    <button type="button"
                           class="btn btn-sm btn-danger btn-language-action"
                           data-directory="{{ language.directory }}"
                           data-url="{{ language.url_sync_keys }}"
                           data-confirm="{{ text_confirm_sync_keys_override }}"
                           data-title="{{ button_sync_keys_override }}"
                           data-mode="sync-override"
                           data-override="1"
                           title="{{ button_sync_keys_override }}">
                     <i class="fa fa-refresh"></i> {{ button_sync_keys_override }}
                    </button>
                  </div>
                </td>
              </tr>
              {# Inline scan results row (hidden until scan is triggered) #}
              <tr id="scan-row-{{ language.directory | replace({'-': '_'}) }}" class="hidden">
                <td colspan="6">
                  <div class="scan-result" id="scan-result-{{ language.directory | replace({'-': '_'}) }}">
                    <i class="fa fa-spinner fa-spin"></i> {{ text_scan_loading }}
                  </div>
                </td>
              </tr>
              {% else %}
              <tr>
                <td colspan="6" class="text-center">{{ text_no_results }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </div>

    {# ══════════════════════════════════════════════════════════════════════ #}
    {# PANEL 2 — Add Languages                                                #}
    {# ══════════════════════════════════════════════════════════════════════ #}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-plus-circle"></i> {{ text_add_language }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ url_add }}" method="post" id="form-add-language">

          {# Reference language selector #}
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ text_reference_language }}</label>
            <div class="col-sm-4">
              <select name="reference" id="input-reference-language" class="form-control">
                {% for dir, preset in presets %}
                <option value="{{ dir }}" {% if dir == 'en-gb' %}selected{% endif %}>
                  {{ preset.name }} ({{ dir }})
                </option>
                {% endfor %}
              </select>
              <p class="help-block">{{ text_reference_help }}</p>
            </div>
          </div>

          {# Language preset checkboxes #}
          <div class="form-group">
            <label class="col-sm-2 control-label">{{ column_name }}</label>
            <div class="col-sm-10">
              <div class="row">
                {% for dir, preset in presets %}
                <div class="col-sm-3 col-md-2" style="margin-bottom:8px;">
                  <div class="checkbox">
                    <label>
                      <input type="checkbox"
                             name="selected[]"
                             value="{{ dir }}"
                             {% if preset.installed %}checked{% endif %}>
                      <strong>{{ preset.native_name }}</strong><br>
                      <small class="text-muted">{{ preset.name }}</small><br>
                      <code style="font-size:10px;">{{ dir }}</code>
                      {% if preset.installed %}
                      <span class="label label-success" style="font-size:9px;">{{ text_installed }}</span>
                      {% endif %}
                    </label>
                  </div>
                </div>
                {% endfor %}
              </div>
            </div>
          </div>

          <div class="form-group">
            <div class="col-sm-offset-2 col-sm-10">
              <button type="submit" class="btn btn-primary">
                <i class="fa fa-save"></i> {{ button_add }}
              </button>
              &nbsp;
              <button type="button" id="btn-select-all" class="btn btn-default">
                <i class="fa fa-check-square-o"></i> {{ text_select_all | default('Select All') }}
              </button>
              <button type="button" id="btn-deselect-all" class="btn btn-default">
                <i class="fa fa-square-o"></i> {{ text_deselect_all | default('Deselect All') }}
              </button>
            </div>
          </div>

        </form>
      </div>
    </div>

  </div>{# /container-fluid #}
</div>{# /content #}
{{ footer }}

{# ── JavaScript ───────────────────────────────────────────────────────────── #}
<script type="text/javascript"><!--
(function ($) {
  function escapeHtml(text) {
    return $('<div>').text(text).html();
  }

  function getReferenceUrl(url, override) {
    var reference = $('#input-reference-language').val() || 'en-gb';
    var separator = url.indexOf('?') === -1 ? '?' : '&';

    url += separator + 'reference=' + encodeURIComponent(reference);

    if (override) {
      url += '&override=1';
    }

    return url;
  }

  function renderActionResult(dir, title, bodyHtml) {
    var rowId = 'scan-row-' + dir.replace(/-/g, '_');
    var resultId = 'scan-result-' + dir.replace(/-/g, '_');
    var $row = $('#' + rowId);
    var $result = $('#' + resultId);

    $row.removeClass('hidden');
    $result.html('<strong>' + escapeHtml(title) + '</strong><br>' + bodyHtml);
  }

  // ── Coverage Scan ──────────────────────────────────────────────────────────
  $(document).on('click', '.btn-scan', function (e) {
    e.preventDefault();

    var dir     = $(this).data('directory');
    var url     = getReferenceUrl($(this).data('url'), false);
    var rowId   = 'scan-row-'    + dir.replace(/-/g, '_');
    var resultId = 'scan-result-' + dir.replace(/-/g, '_');
    var $row    = $('#' + rowId);
    var $result = $('#' + resultId);

    $row.removeClass('hidden');
    $result.html('<i class="fa fa-spinner fa-spin"></i> {{ text_scan_loading }}');

    $.getJSON(url, function (data) {
      if (data.error) {
        $result.html('<span class="text-danger"><i class="fa fa-times-circle"></i> ' + escapeHtml(data.error) + '</span>');
        return;
      }

      var html = '<strong>{{ text_scan_result }}</strong><br>';
      $.each(data.report, function (area, info) {
        var mf = info.missing_files;
        var mk = info.missing_keys;
        var areaLabel = area.charAt(0).toUpperCase() + area.slice(1);
        html += '<strong>' + areaLabel + '</strong>: ';
        if (mf === 0 && mk === 0) {
          html += '<span class="text-success"><i class="fa fa-check"></i> {{ text_scan_ok }}</span>';
        } else {
          if (mf > 0) html += '<span class="text-danger">{{ text_scan_missing_files }}: ' + mf + '</span> &nbsp; ';
          if (mk > 0) html += '<span class="text-warning">{{ text_scan_missing_keys }}: ' + mk + '</span>';
        }
        html += '<br>';

        // Show missing file list if any
        if (mf > 0 && info.details && info.details.missing_files) {
          html += '<ul class="text-danger small">';
          $.each(info.details.missing_files, function (i, f) {
            html += '<li>' + escapeHtml(f) + '</li>';
          });
          html += '</ul>';
        }
      });
      $result.html(html);
    }).fail(function () {
      $result.html('<span class="text-danger"><i class="fa fa-times-circle"></i> {{ text_ajax_error }}</span>');
    });
  });

  $(document).on('click', '.btn-language-action', function (e) {
    e.preventDefault();

    var $button = $(this);
    var dir = $button.data('directory');
    var url = getReferenceUrl($button.data('url'), !!$button.data('override'));
    var title = $button.data('title');
    var confirmText = $button.data('confirm');
    var originalHtml = $button.html();

    if (confirmText && !window.confirm(confirmText)) {
      return;
    }

    $button.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i>');
    renderActionResult(dir, title, '<i class="fa fa-spinner fa-spin"></i> {{ text_scan_loading }}');

    $.getJSON(url, function (data) {
      var html = '';

      if (data.error) {
        html = '<span class="text-danger"><i class="fa fa-times-circle"></i> ' + escapeHtml(data.error) + '</span>';
      } else if ($button.data('mode') === 'scaffold') {
        $.each(data.results || {}, function (area, info) {
          var created = (info.created || []).length;
          var errors = info.errors || [];

          html += '<strong>' + escapeHtml(area.charAt(0).toUpperCase() + area.slice(1)) + '</strong>: ';
          html += '<span class="text-success">' + escapeHtml('{{ text_files_scaffolded }}'.replace('%d', created)) + '</span>';

          if (errors.length) {
            html += '<ul class="text-danger small">';
            $.each(errors, function (index, error) {
              html += '<li>' + escapeHtml(error) + '</li>';
            });
            html += '</ul>';
          } else {
            html += '<br>';
          }
        });
      } else {
        html += '<span class="' + (data.success ? 'text-success' : 'text-warning') + '"><i class="fa ' + (data.success ? 'fa-check' : 'fa-exclamation-triangle') + '"></i> ';
        html += escapeHtml('{{ text_keys_processed }}'.replace('%d', data.keys_appended)) + '</span>';

        if (data.errors && data.errors.length) {
          html += '<ul class="text-danger small">';
          $.each(data.errors, function (index, error) {
            html += '<li>' + escapeHtml(error) + '</li>';
          });
          html += '</ul>';
        }
      }

      if (!html) {
        html = '<span class="text-success"><i class="fa fa-check"></i> {{ text_action_success }}</span>';
      }

      renderActionResult(dir, '{{ text_action_result }}: ' + title, html);
    }).fail(function () {
      renderActionResult(dir, '{{ text_action_result }}: ' + title, '<span class="text-danger"><i class="fa fa-times-circle"></i> {{ text_ajax_error }}</span>');
    }).always(function () {
      $button.prop('disabled', false).html(originalHtml);
    });
  });

  // ── Quick select/deselect all ─────────────────────────────────────────────
  $('#btn-select-all').on('click', function () {
    $('input[name="selected[]"]').prop('checked', true);
  });
  $('#btn-deselect-all').on('click', function () {
    $('input[name="selected[]"]').prop('checked', false);
  });

}(jQuery));
//--></script>
